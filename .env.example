# Repo-local paths may stay in OneDrive; data must stay on the external drive.
PROJECT_ROOT="/path/to/reporting-risk-cascade"
WORK_DIR="/path/to/reporting-risk-cascade"
DATA_DIR="/Volumes/ExternalSSD/data/reporting-risk-cascade"
DOCS_DIR="/path/to/reporting-risk-cascade/docs"
PAPER_DIR="/path/to/reporting-risk-cascade/doc"
ARTIFACTS_DIR="/path/to/reporting-risk-cascade/artifacts"
DEFAULT_CONFIG_PATH="/path/to/reporting-risk-cascade/config/data_prep.yaml"
RAW_DATASET_PATH="/Volumes/ExternalSSD/data/reporting-risk-cascade/raw/raw_dataset_misstatement.parquet"
PUBLIC_LAKE_DIR="/Volumes/ExternalSSD/data/reporting-risk-cascade/public_lake"
LAKE_BRONZE_DIR="/Volumes/ExternalSSD/data/reporting-risk-cascade/public_lake/bronze"
LAKE_SILVER_DIR="/Volumes/ExternalSSD/data/reporting-risk-cascade/public_lake/silver"
LAKE_GOLD_DIR="/Volumes/ExternalSSD/data/reporting-risk-cascade/public_lake/gold"

# Keep the uv environment outside the repo so generated environments stay local.
UV_PROJECT_ENVIRONMENT="${HOME}/.venvs/reporting-risk-cascade"

# Local manuscript exports are intentionally outside the repo.
MANUSCRIPT_DIR="${HOME}/reporting-risk-cascade-manuscript"

SEED_DEFAULT="42"
